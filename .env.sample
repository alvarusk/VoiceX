# Copia este archivo a .env para desarrollo local únicamente.
# Para builds de distribución, pasa las claves con --dart-define (ver scripts/README.md).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_USER_EMAIL=
SUPABASE_USER_PASSWORD=
# Alternativa para shells/problemáticas con caracteres especiales en iOS/macOS:
# SUPABASE_USER_PASSWORD_B64=$(printf %s 'tu_password' | base64)
SUPABASE_USER_PASSWORD_B64=

R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=
